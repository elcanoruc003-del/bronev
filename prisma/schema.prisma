generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model audit_logs {
  id        String   @id
  userId    String?
  action    String
  entity    String
  entityId  String?
  changes   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  users     users?   @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([entity, entityId])
  @@index([userId])
}

model bookings {
  id                 String        @id
  checkIn            DateTime      @db.Date
  checkOut           DateTime      @db.Date
  totalPrice         Int
  status             BookingStatus @default(PENDING)
  guestName          String
  guestPhone         String
  guestEmail         String
  propertyId         String
  userId             String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime
  basePrice          Int
  bookingNumber      String        @unique
  cancellationReason String?
  cancelledAt        DateTime?
  cancelledBy        String?
  cleaningFee        Int           @default(0)
  completedAt        DateTime?
  confirmedAt        DateTime?
  discountAmount     Int           @default(0)
  emailSent          Boolean       @default(false)
  guestCount         Int
  paidAmount         Int           @default(0)
  paymentMethod      String?
  paymentStatus      PaymentStatus @default(UNPAID)
  promoCode          String?
  promoDiscount      Int           @default(0)
  refundAmount       Int?
  serviceFee         Int           @default(0)
  smsSent            Boolean       @default(false)
  specialRequests    String?
  taxes              Int           @default(0)
  totalNights        Int
  whatsappSent       Boolean       @default(false)
  properties         properties    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  users              users?        @relation(fields: [userId], references: [id])

  @@index([bookingNumber])
  @@index([checkIn, checkOut])
  @@index([createdAt])
  @@index([propertyId])
  @@index([status])
  @@index([userId])
}

model favorites {
  id         String     @id
  propertyId String
  userId     String
  createdAt  DateTime   @default(now())
  properties properties @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  users      users      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([propertyId, userId])
  @@index([createdAt])
  @@index([userId])
}

model notifications {
  id        String           @id
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  users     users            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId, isRead])
}

model pricing_rules {
  id              String          @id
  propertyId      String
  name            String
  description     String?
  type            PricingRuleType
  startDate       DateTime        @db.Date
  endDate         DateTime        @db.Date
  adjustmentType  AdjustmentType
  adjustmentValue Int
  daysOfWeek      Int[]           @default([])
  priority        Int             @default(0)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  properties      properties      @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([propertyId])
  @@index([startDate, endDate])
}

model properties {
  id                     String                  @id
  title                  String
  slug                   String                  @unique
  city                   String
  district               String
  address                String
  latitude               Float
  longitude              Float
  type                   PropertyType
  bedrooms               Int
  bathrooms              Float
  area                   Int
  floor                  Int?
  totalFloors            Int?
  status                 PropertyStatus          @default(DRAFT)
  featured               Boolean                 @default(false)
  verified               Boolean                 @default(false)
  metaTitle              String?
  metaDescription        String?
  metaKeywords           String[]
  views                  Int                     @default(0)
  inquiries              Int                     @default(0)
  ownerId                String
  createdAt              DateTime                @default(now())
  updatedAt              DateTime
  archivedAt             DateTime?
  averageRating          Float                   @default(0)
  badges                 String[]                @default([])
  basePricePerNight      Int
  beds                   Int
  bookings               Int                     @default(0)
  canonicalUrl           String?
  checkInTime            String                  @default("14:00")
  checkOutTime           String                  @default("12:00")
  cleaningFee            Int                     @default(0)
  country                String                  @default("Azerbaijan")
  extraGuestFee          Int                     @default(0)
  instantBook            Boolean                 @default(false)
  longDescription        String
  maxGuests              Int
  maxNights              Int                     @default(365)
  minNights              Int                     @default(1)
  monthlyDiscount        Int                     @default(0)
  monthlyPrice           Int?
  publishedAt            DateTime?
  responseRate           Float                   @default(0)
  responseTime           Int                     @default(0)
  rules                  Json                    @default("{}")
  securityDeposit        Int                     @default(0)
  shortDescription       String
  totalReviews           Int                     @default(0)
  weekendPriceMultiplier Float                   @default(1.0)
  weeklyDiscount         Int                     @default(0)
  weeklyPrice            Int?
  zipCode                String?
  features               Json                    @default("[]")
  amenities              Json                    @default("[]")
  bookingRequests        bookings[]
  favorites              favorites[]
  pricing_rules          pricing_rules[]
  users                  users                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  property_availability  property_availability[]
  property_images        property_images[]
  reviews                reviews[]

  @@index([averageRating])
  @@index([basePricePerNight])
  @@index([city])
  @@index([createdAt])
  @@index([featured])
  @@index([ownerId])
  @@index([slug])
  @@index([status])
  @@index([type])
}

model property_availability {
  id          String     @id
  propertyId  String
  startDate   DateTime   @db.Date
  endDate     DateTime   @db.Date
  isAvailable Boolean    @default(true)
  blockReason String?
  customPrice Int?
  minNights   Int?
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime
  properties  properties @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, startDate, endDate])
  @@index([propertyId, startDate, endDate])
  @@index([startDate, endDate])
}

model property_images {
  id           String     @id
  url          String
  alt          String?
  order        Int        @default(0)
  propertyId   String
  createdAt    DateTime   @default(now())
  caption      String?
  height       Int?
  isCover      Boolean    @default(false)
  size         Int?
  thumbnailUrl String?
  width        Int?
  properties   properties @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([isCover])
  @@index([propertyId])
}

model reviews {
  id                  String     @id
  comment             String
  propertyId          String
  userId              String
  createdAt           DateTime   @default(now())
  updatedAt           DateTime
  accuracyRating      Int
  cleanlinessRating   Int
  communicationRating Int
  cons                String?
  images              String[]   @default([])
  isPublished         Boolean    @default(true)
  isVerified          Boolean    @default(false)
  locationRating      Int
  overallRating       Int
  ownerRespondedAt    DateTime?
  ownerResponse       String?
  pros                String?
  valueRating         Int
  properties          properties @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  users               users      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([propertyId, userId])
  @@index([isPublished])
  @@index([overallRating])
  @@index([propertyId])
  @@index([userId])
}

model users {
  id               String          @id
  name             String
  email            String          @unique
  phone            String?         @unique
  password         String
  role             UserRole        @default(USER)
  emailVerified    DateTime?
  image            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime
  bannedAt         DateTime?
  bannedReason     String?
  bio              String?
  isActive         Boolean         @default(true)
  isBanned         Boolean         @default(false)
  language         String          @default("az")
  lastLoginAt      DateTime?
  lastLoginIp      String?
  phoneVerified    DateTime?
  timezone         String          @default("Asia/Baku")
  twoFactorEnabled Boolean         @default(false)
  audit_logs       audit_logs[]
  bookings         bookings[]
  favorites        favorites[]
  notifications    notifications[]
  properties       properties[]
  reviews          reviews[]

  @@index([email])
  @@index([isActive])
  @@index([phone])
  @@index([role])
}

enum AdjustmentType {
  PERCENTAGE
  FIXED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  CHECKED_IN
  CHECKED_OUT
}

enum NotificationType {
  BOOKING_REQUEST
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  PAYMENT_RECEIVED
  REVIEW_RECEIVED
  MESSAGE_RECEIVED
  SYSTEM_ALERT
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  REFUNDED
  FAILED
}

enum PricingRuleType {
  SEASONAL
  WEEKEND
  HOLIDAY
  EARLY_BIRD
  LAST_MINUTE
  LONG_STAY
}

enum PropertyStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  MAINTENANCE
  SUSPENDED
}

enum PropertyType {
  VILLA
  APARTMENT
  HOUSE
  PENTHOUSE
  COTTAGE
  STUDIO
  LOFT
}

enum UserRole {
  USER
  ADMIN
  OWNER
  SUPER_ADMIN
}
